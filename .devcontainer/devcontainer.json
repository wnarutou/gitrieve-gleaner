{
  "name": "Claude Code Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "mounts": [
    "source=${localWorkspaceFolder}\\..\\.claude-code-router,target=/home/vscode/.claude-code-router,type=bind"
  ],
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code;npm install -g @musistudio/claude-code-router",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint"
      ]
    }
  },
  "remoteUser": "vscode"
}
